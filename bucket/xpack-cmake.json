{
    "version": "3.31.9-1",
    "description": "A binary distribution of CMake from xPack.",
    "homepage": "https://xpack-dev-tools.github.io/cmake-xpack/",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/xpack-dev-tools/cmake-xpack/releases/download/v3.31.9-1/xpack-cmake-3.31.9-1-win32-x64.zip",
            "hash": "fbb9233a1a16347ca58ae874d2c148a5744b9358607fe16abb665637a05567e3"
        }
    },
    "extract_dir": "xpack-cmake-3.31.9-1",
    "env_add_path": "bin",
    "checkver": {
        "github": "https://github.com/xpack-dev-tools/cmake-xpack",
        "regex": "releases/tag/v([\\d.]+-[\\d.]+)\""
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/xpack-dev-tools/cmake-xpack/releases/download/v$version/xpack-cmake-$version-win32-x64.zip"
            }
        },
        "hash": {
            "url": "$url.sha",
            "regex": "^([a-fA-F0-9]+)"
        },
        "extract_dir": "xpack-cmake-$version"
    }
}
